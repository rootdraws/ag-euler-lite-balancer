{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "postinstall": "nuxt prepare && simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs,mts}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@floating-ui/vue": "1.1.6",
    "@gvade/nuxt3-svg-sprite": "1.0.3",
    "@nuxt/eslint": "1.0.1",
    "@nuxt/kit": "3.17.4",
    "@pythnetwork/price-service-client": "1.9.1",
    "@reown/appkit": "1.8.7",
    "@reown/appkit-adapter-wagmi": "1.8.7",
    "@tanstack/vue-query": "5.90.2",
    "@vueuse/nuxt": "13.3.0",
    "@wagmi/vue": "0.2.10",
    "axios": "1.13.5",
    "chart.js": "4.5.1",
    "chartjs-plugin-annotation": "3.1.0",
    "luxon": "3.4.4",
    "modern-normalize": "3.0.1",
    "nuxt": "3.16.1",
    "viem": "2.44.2",
    "vue": "3.5.16",
    "vue-chartjs": "5.3.3",
    "vue-router": "4.3.0"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "6.14.0",
    "@types/luxon": "3.4.2",
    "eslint": "9.39.2",
    "lint-staged": "16.2.7",
    "playwright": "^1.58.2",
    "sass": "1.84.0",
    "simple-git-hooks": "2.13.1",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vue-tsc": "2.2.12"
  }
}
